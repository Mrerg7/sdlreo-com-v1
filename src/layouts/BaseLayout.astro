---
import '../styles/global.css';
import { SITE, OG_IMAGE, ACQUISITION_MAILTO, DOMAIN_PRODUCT } from '../config/site';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
}

const {
  title = SITE.title,
  description = SITE.description,
  ogImage = OG_IMAGE,
  noindex = false,
} = Astro.props;

const pathname = Astro.url.pathname.endsWith('/') ? Astro.url.pathname : `${Astro.url.pathname}/`;
const canonicalURL = new URL(pathname, SITE.url);
const publishedDate = '2026-07-07';

const productReview = {
  '@type': 'Review',
  name: 'sdlreo.com Premium Domain Assessment',
  author: {
    '@type': 'Organization',
    name: DOMAIN_PRODUCT.reviewAuthor,
  },
  reviewRating: {
    '@type': 'Rating',
    ratingValue: DOMAIN_PRODUCT.editorialRating,
    bestRating: 5,
  },
  positiveNotes: {
    '@type': 'ItemList',
    itemListElement: [
      {
        '@type': 'ListItem',
        position: 1,
        name: 'Instant REO authority — short, professional, memorable Scottsdale REO branding',
      },
      {
        '@type': 'ListItem',
        position: 2,
        name: "Scottsdale's premium opportunity in Arizona's most desirable luxury market",
      },
      {
        '@type': 'ListItem',
        position: 3,
        name: 'Rare exact-match domain for specialized REO real estate verticals',
      },
    ],
  },
};

const productOffers = DOMAIN_PRODUCT.listPrice
  ? {
      '@type': 'Offer',
      url: ACQUISITION_MAILTO,
      price: DOMAIN_PRODUCT.listPrice,
      priceCurrency: DOMAIN_PRODUCT.priceCurrency,
      priceValidUntil: DOMAIN_PRODUCT.priceValidUntil,
      availability: 'https://schema.org/InStock',
      seller: {
        '@type': 'Organization',
        name: SITE.name,
        email: SITE.email,
      },
    }
  : undefined;

const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': `${SITE.url}#website`,
      url: SITE.url,
      name: SITE.name,
      description,
      inLanguage: 'en-US',
    },
    {
      '@type': 'WebPage',
      '@id': `${SITE.url}#webpage`,
      url: SITE.url,
      name: title,
      description,
      isPartOf: { '@id': `${SITE.url}#website` },
      datePublished: publishedDate,
      dateModified: publishedDate,
      inLanguage: 'en-US',
    },
    {
      '@type': 'Product',
      '@id': `${SITE.url}#product`,
      name: 'sdlreo.com Premium Domain Name',
      description:
        'The premium domain for Scottsdale REO and bank-owned real estate — short, authoritative, and market-specific. Available for acquisition.',
      url: SITE.url,
      image: OG_IMAGE,
      category: 'Premium Domain Name',
      brand: {
        '@type': 'Brand',
        name: 'sdlreo.com',
      },
      review: productReview,
      aggregateRating: {
        '@type': 'AggregateRating',
        ratingValue: DOMAIN_PRODUCT.editorialRating,
        bestRating: 5,
        reviewCount: 1,
      },
      ...(productOffers ? { offers: productOffers } : {}),
    },
    {
      '@type': 'Organization',
      '@id': `${SITE.url}#organization`,
      name: SITE.name,
      url: SITE.url,
      email: SITE.email,
      address: {
        '@type': 'PostalAddress',
        addressLocality: 'Scottsdale',
        addressRegion: 'AZ',
        addressCountry: 'US',
      },
    },
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={noindex ? 'noindex' : 'index, follow, max-image-preview:large'} />
    <link rel="canonical" href={canonicalURL} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:secure_url" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="sdlreo.com — Premium Domain for Scottsdale REO Real Estate" />
    <meta property="og:locale" content={SITE.locale} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="sdlreo.com — Premium Domain for Scottsdale REO Real Estate" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    {SITE.googleSiteVerification && (
      <meta name="google-site-verification" content={SITE.googleSiteVerification} />
    )}
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  </head>
  <body>
    <slot />
  </body>
</html>
