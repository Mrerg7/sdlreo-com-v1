---
import { getCollection } from 'astro:content';

const items = (await getCollection('useCases')).sort((a, b) => a.data.order - b.data.order);
---

<section class="bg-white border-y border-slate-100 py-16" id="perfect-for">
  <div class="max-w-5xl mx-auto px-6">
    <div class="max-w-xl mb-10">
      <div class="uppercase tracking-[2px] text-xs font-semibold text-amber-brand mb-3">IDEAL USE CASES</div>
      <h2 class="text-4xl tracking-tighter font-semibold">
        Built for leaders in REO and motivated seller real estate.
      </h2>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
      {
        items.map(({ data }) => (
          <div class="group border border-slate-200 hover:border-amber-200 transition-colors rounded-3xl p-7 bg-white">
            <div class="text-3xl mb-4">{data.icon}</div>
            <div class="font-semibold text-xl tracking-tight">{data.title}</div>
            <p class="mt-3 text-sm text-slate-600">{data.description}</p>
            <div class="mt-5 text-xs font-medium text-amber-brand group-hover:underline">{data.tagline}</div>
          </div>
        ))
      }
    </div>
  </div>
</section>
