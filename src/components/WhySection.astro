---
import { getCollection } from 'astro:content';

const items = (await getCollection('valueProps')).sort((a, b) => a.data.order - b.data.order);
---

<section id="why" class="max-w-5xl mx-auto px-6 pt-16 pb-12">
  <div class="max-w-2xl">
    <div class="uppercase tracking-[2px] text-xs font-semibold text-amber-brand mb-3">THE OPPORTUNITY</div>
    <h2 class="text-5xl tracking-tighter font-semibold font-display">
      Own the definitive domain<br />for Scottsdale REO real estate.
    </h2>
    <p class="mt-5 text-lg text-slate-600">
      sdlreo.com is short, powerful, and instantly communicates expertise in Real Estate Owned
      (bank-owned) properties in Scottsdale. It positions the owner as the go-to authority for
      motivated seller opportunities, below-market deals, and REO investment in Arizona's most
      prestigious and influential real estate market.
    </p>
  </div>

  <div class="mt-12 grid md:grid-cols-3 gap-5">
    {
      items.map(({ data }) => (
        <div class="value-card bg-white border border-slate-200 rounded-3xl p-7">
          <div class="text-amber-brand text-xs tracking-widest font-semibold mb-3">{data.eyebrow}</div>
          <div class="font-semibold text-xl tracking-tight">{data.title}</div>
          <p class="mt-3 text-sm text-slate-600">{data.description}</p>
        </div>
      ))
    }
  </div>
</section>
