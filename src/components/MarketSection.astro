---
import { getCollection } from 'astro:content';

const items = (await getCollection('marketStats')).sort((a, b) => a.data.order - b.data.order);
---

<section class="max-w-5xl mx-auto px-6 py-16" id="market">
  <div class="max-w-2xl mb-10">
    <div class="uppercase tracking-[2px] text-xs font-semibold text-amber-brand mb-3">THE MARKET</div>
    <h2 class="text-4xl tracking-tighter font-semibold">
      Scottsdale offers compelling opportunities in the REO and motivated seller segment.
    </h2>
    <p class="mt-4 text-slate-600">
      While Scottsdale is known for its premium luxury market, REO (Real Estate Owned) properties
      present unique value opportunities — often priced below market due to motivated bank sellers,
      as-is condition, and the desire for quick liquidation.
    </p>
  </div>

  <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
    {
      items.map(({ data }) => (
        <div class="bg-white border border-slate-200 rounded-3xl p-7">
          <div class="text-amber-brand text-xs tracking-widest font-semibold mb-2">{data.eyebrow}</div>
          <div class="font-semibold text-lg">{data.title}</div>
          <p class="mt-3 text-sm text-slate-600">{data.description}</p>
        </div>
      ))
    }
  </div>

  <div class="mt-8 text-xs text-slate-500 max-w-3xl">
    REO characteristics and market insights based on standard real estate practices and Scottsdale's
    position as Arizona's premier luxury and high-value real estate market. Individual property
    conditions and pricing vary.
  </div>
</section>
