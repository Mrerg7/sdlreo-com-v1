---
import { ACQUISITION_MAILTO } from '../config/site';
---

<nav class="bg-white/95 backdrop-blur-md border-b border-slate-200 sticky top-0 z-50">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="flex justify-between items-center h-16 sm:h-20 gap-3">
      <a href="/" class="flex items-center gap-x-2 sm:gap-x-3 min-w-0">
        <div class="w-8 h-8 sm:w-9 sm:h-9 shrink-0 bg-slate-900 rounded-2xl flex items-center justify-center">
          <span class="text-white font-bold text-base sm:text-xl tracking-tighter">SDL</span>
        </div>
        <div class="font-semibold text-base sm:text-xl tracking-tighter text-slate-900 truncate">
          sdlreo<span class="text-amber-brand">.</span>com
        </div>
      </a>

      <div class="hidden md:flex items-center gap-x-8 text-sm font-medium">
        <a href="#why" class="text-slate-600 hover:text-slate-900 transition-colors">Why This Domain</a>
        <a href="#perfect-for" class="text-slate-600 hover:text-slate-900 transition-colors">Perfect For</a>
        <a href="#market" class="text-slate-600 hover:text-slate-900 transition-colors">Scottsdale REO Market</a>
        <a href="#acquire" class="text-slate-600 hover:text-slate-900 transition-colors">Inquire</a>
      </div>

      <div class="flex items-center gap-x-2 sm:gap-x-3 shrink-0">
        <a
          href="https://sdl.contact"
          target="_blank"
          rel="noopener noreferrer"
          class="hidden md:inline text-xs px-4 py-2 border border-slate-300 hover:bg-slate-100 rounded-3xl font-medium text-slate-600 transition-colors"
        >
          SDL Portfolio
        </a>
        <a
          href={ACQUISITION_MAILTO}
          class="px-4 sm:px-6 py-2 sm:py-2.5 bg-slate-900 hover:bg-black text-white text-xs sm:text-sm font-semibold rounded-3xl transition-all active:scale-[0.985] whitespace-nowrap"
        >
          <span class="sm:hidden">Offer</span>
          <span class="hidden sm:inline">Make an Offer</span>
        </a>
      </div>
    </div>
  </div>
</nav>

<script>
  window.addEventListener('scroll', () => {
    const nav = document.querySelector('nav');
    if (!nav) return;
    if (window.scrollY > 20) {
      nav.classList.add('nav-scrolled');
    } else {
      nav.classList.remove('nav-scrolled');
    }
  });
</script>
